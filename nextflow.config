/*
========================================================================================
    Chimeric Interaction Sequence Extraction Pipeline Configuration
========================================================================================
*/

params {
    // Input/Output options
    input              = null        // Path to samplesheet (TSV: sample_id, file_path)
    input_pattern      = null        // Glob pattern for input files (e.g., "data/*.txt")
    fasta              = null        // Path to reference genome FASTA file
    outdir             = './results' // Output directory

    // Processing options
    chunk_size         = 10000       // Number of rows per chunk

    // Resource options
    max_cpus           = 4
    max_memory         = 8.GB
    max_time           = 24.h
}

// Load base.config by default
includeConfig 'conf/base.config'

//  Sets a publishDir directive for all processes and defines the output directory dynamically
process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

}

// Process-specific configurations
process {
    // Default resources
    cpus   = 1
    memory = 4.GB
    time   = 4.h

    withName: SPLIT_TABLE {
        cpus   = 1
        memory = 2.GB
    }

    withName: PREPARE_BED {
        cpus   = 1
        memory = 2.GB
    }

    withName: EXTRACT_SEQUENCES {
        cpus   = 2
        memory = 4.GB
    }

    withName: ADD_SEQUENCES {
        cpus   = 1
        memory = 2.GB
    }

    withName: CONCATENATE_TABLES {
        cpus   = 1
        memory = 4.GB
    }
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'community.wave.seqera.io/library/bedtools_python:88ef333ca5f1123a'
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.container = 'https://depot.galaxyproject.org/singularity/bedtools:2.31.1--hf5e1c6e_1'
    }

    conda {
        conda.enabled = true
        process.conda = 'bioconda::bedtools=2.31.1'
    }
}

// Manifest
manifest {
    name            = 'nf-mfe'
    author          = 'Ira Iosub & Seqera AI'
    homePage        = ''
    description     = 'Extract sequences for chimeric interaction coordinates'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// Report options
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
}
